# https://trello.com/1/authorize?expiration=never&name=bbbrindes&scope=read,write&response_type=token&key=SUA_API_KEY
TRELLO_API_KEY=00000000000000000000000000000000
TRELLO_TOKEN=ATTAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
